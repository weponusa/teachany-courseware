{
  "version": "1.0",
  "globalBanNames": [
    "批判性思维", "创新思维", "团队协作", "团队合作", "项目管理", "沟通能力",
    "核心素养", "综合素养", "学会学习", "责任担当"
  ],
  "writingRules": [
    { "match": "说明文", "subtype": "expository", "allowArchetypes": ["consumer-decision", "social-inquiry", "business-economics", "health-life", "general-practice", "life-planning"] },
    { "match": "应用文", "subtype": "expository", "allowArchetypes": ["consumer-decision", "social-inquiry", "business-economics", "life-planning"] },
    { "match": "调查报告", "subtype": "expository", "allowArchetypes": ["social-inquiry", "consumer-decision", "health-life"] },
    { "match": "非连续", "subtype": "expository", "allowArchetypes": ["consumer-decision", "social-inquiry"] },
    { "match": "人物描写", "subtype": "literary", "banArchetypes": ["consumer-decision", "social-inquiry", "business-economics", "health-life", "life-planning"] },
    { "match": "性格分析", "subtype": "literary", "banArchetypes": ["consumer-decision", "social-inquiry", "business-economics"] },
    { "match": "诗词", "subtype": "literary", "banArchetypes": ["consumer-decision", "social-inquiry", "business-economics", "engineering", "scientific-inquiry"] },
    { "match": "文言", "subtype": "literary", "banArchetypes": ["consumer-decision", "social-inquiry", "engineering"] },
    { "match": "记叙", "subtype": "narrative", "banArchetypes": ["consumer-decision", "social-inquiry"] },
    { "match": "现代诗", "subtype": "literary", "allowArchetypes": ["humanities-writing"] },
    { "match": "议论文", "subtype": "argument", "allowArchetypes": ["humanities-writing", "social-inquiry"] }
  ],
  "elementaryBanPatterns": [
    "100以内", "20以内", "认识图形", "数一数", "比一比", "分与合"
  ],
  "competencyAnchors": {
    "titration": ["滴定", "硝酸银", "物质的量浓度", "离子检验"],
    "survey": ["数据的收集", "数据的描述", "统计"],
    "argument-report": ["说明文阅读", "应用文", "调查报告"],
    "projectile": ["抛体运动", "牛顿运动定律", "动量"],
    "cost-model": ["函数模型", "百分比", "统计"]
  }
}
