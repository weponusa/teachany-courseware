    {
      "kp_id": "kp-bio-h-homeostasis-bio-h-plant-hormone",
      "text": "举例说明生长素、细胞分裂素、赤霉素、脱落酸和乙烯等植物激素及其类似物在生产上得到了广泛应用",
      "source": "内容要求",
      "type": "curriculum_point"
