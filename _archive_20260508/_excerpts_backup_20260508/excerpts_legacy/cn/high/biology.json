    {
      "kp_id": "kp-bio-h-variation-evolution-bio-h-natural-selection",
      "text": "选取的现代生物进化理论和物种形成等知识，主要是为了阐明生物进化的过程和原因。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-h-homeostasis-bio-h-immune-regulation",
      "text": "免疫调节是机体维持内环境稳态的重要机制，包括非特异性免疫和特异性免疫。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-h-homeostasis-bio-h-immune-regulation",
      "text": "举例说明免疫细胞、免疫器官和免疫活性物质等是免疫调节的结构与物质基础。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-h-homeostasis-bio-h-immune-regulation",
      "text": "阐明特异性免疫是通过体液免疫和细胞免疫两种方式，针对特定病原体发生的免疫应答。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-h-ecology-bio-h-population",
      "text": "种群是生物进化的基本单位，在一定空间内，同种生物所有个体形成的集合就是种群。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-h-ecology-bio-h-population",
      "text": "不同种群在自然条件下基因不能自由交流的现象称为隔离。隔离是物种形成的必要条件。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-h-ecology-bio-h-population",
      "text": "阐明具有优势性状的个体在种群中所占比例将会增加。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-h-ecology-bio-h-ecosystem",
      "text": "选择性必修部分有“稳态与调节”“生物与环境”和“生物技术与工程”三个模块",
      "source": "课程结构",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-h-ecology-bio-h-ecosystem",
      "text": "选择性必修课程所选的内容是学生未来职业与专业发展的基础，有助于学生进一步加深对生物学大概念的理解",
      "source": "课程结构",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-h-homeostasis-bio-h-humoral-regulation",
      "text": "概念1 动物生命活动的调节包括神经调节、体液调节和免疫调节等方式，它们共同维持机体的稳态",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-h-homeostasis-bio-h-humoral-regulation",
      "text": "举例说明神经调节与体液调节相互协调，共同维持机体的稳态，如体温调节、水盐平衡调节等",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-h-homeostasis-bio-h-humoral-regulation",
      "text": "举例说明其他体液成分参与稳态的调节，如二氧化碳对呼吸运动的调节",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-h-ecology-bio-h-ecosystem-stability",
      "text": "生态系统的稳定性是指生态系统保持或恢复自身结构和功能相对稳定的能力。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-h-ecology-bio-h-ecosystem-stability",
      "text": "阐明生态系统通过自我调节作用抵御和消除一定限度的外来干扰，保持或恢复相对稳定的状态。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-h-ecology-bio-h-ecosystem-stability",
      "text": "举例说明生态系统的稳定性会受到自然或人为因素的影响，如气候变化、人类活动等。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-h-ecology-bio-h-community",
      "text": "本模块包括遗传的细胞基础、遗传的分子基础、遗传的基本规律、生物的变异和生物的进化等内容。",
