    {
      "kp_id": "kp-chn-m-classical-chinese-chn-m-classical-translation",
      "text": "能借助工具书阅读浅易文言文。",
      "source": "总目标",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-chn-m-classical-chinese-chn-m-classical-translation",
      "text": "诵读优秀诗文，注意在诵读过程中体验情感，展开想象，领悟诗文大意。",
      "source": "学段要求（阅读与鉴赏）",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-chn-m-language-use-chn-m-word-usage",
      "text": "在具体的语言情境中独立识字写字；关注有新鲜感的词句，并有意识地在口头和书面表达中运用。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-chn-m-language-use-chn-m-word-usage",
      "text": "能联系上下文，理解词句的意思，体会课文中关键词句表达情意的作用。能借助字典、词典和生活积累，理解生词的意义。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-chn-m-classical-chinese-chn-m-classical-sentences",
      "text": "能借助工具书阅读浅易文言文。",
      "source": "总目标",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-chn-m-classical-chinese-chn-m-classical-sentences",
      "text": "在理解语句的过程中，体会句号与逗号的不同用法，了解冒号、引号的一般用法。",
      "source": "第二学段阅读与鉴赏",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-chn-m-language-use-chn-m-rhetoric-analysis",
      "text": "关注有新鲜感的词句，并有意识地在口头和书面表达中运用。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-chn-m-language-use-chn-m-rhetoric-analysis",
      "text": "能从多个角度分析作品中的优美词语、精彩段落。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-chn-m-language-use-chn-m-rhetoric-analysis",
      "text": "感受语言文字的丰富内涵，对国家通用语言文字具有深厚感情。",
      "source": "核心素养内涵",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-chn-m-classical-chinese-chn-m-classical-words",
      "text": "能借助工具书阅读浅易文言文。",
      "source": "总目标",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-chn-m-classical-chinese-chn-m-classical-words",
      "text": "在理解语句的过程中，体会句号与逗号的不同用法，了解冒号、引号的一般用法。",
      "source": "第二学段阅读与鉴赏",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-chn-m-language-use-chn-m-comprehensive-language",
      "text": "学会倾听与表达，初步学会用口头语言文明地进行人际沟通和社会交往。",
      "source": "学段要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-chn-m-language-use-chn-m-comprehensive-language",
      "text": "乐于用口头、书面的方式与人交流沟通，愿意与他人分享，增强表达的自信心。",
      "source": "学段要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-chn-m-language-use-chn-m-comprehensive-language",
      "text": "能主动参与日常生活中的文化活动，根据不同的场合，尝试运用合适的音量和语气与他人交流，有礼貌地请教、回应。",
      "source": "学段要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-chn-m-modern-reading-chn-m-prose-reading",
      "text": "阅读表现人与社会、人与他人的古今优秀诗歌、散文、小说、戏剧等文学作品，学习欣赏、品味作品的语言、形象等，交流审美体验。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-chn-m-modern-reading-chn-m-prose-reading",
      "text": "独立阅读古今中外诗歌集、中长篇小说、散文集等文学名著，根据阅读进度完成读书笔记，针对作品的语言、形象、主题等方面的话题展开研讨。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-chn-m-modern-reading-chn-m-prose-reading",
      "text": "能从多个角度分析作品中的人物行为、人物形象、作品中的优美词语、精彩段落，并根据需要进行摘录。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-chn-m-language-use-chn-m-sentence-logic",
      "text": "能联系上下文，理解词句的意思，体会课文中关键词句表达情意的作用。",
