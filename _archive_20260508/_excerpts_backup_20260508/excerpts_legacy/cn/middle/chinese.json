      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-chn-m-language-use-chn-m-sentence-logic",
      "text": "能借助上下文语域，说出关键语句、标点符号、图表在表达中的作用。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
