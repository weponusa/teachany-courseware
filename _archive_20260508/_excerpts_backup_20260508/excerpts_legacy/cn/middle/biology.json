  "tree_path": "cn/middle/biology.json",
  "excerpts": [
    {
      "kp_id": "kp-bio-m-cell-basis-bio-m-cell-life-activities",
      "text": "细胞不同结构的功能各不相同，共同完成细胞的各项生命活动。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-cell-basis-bio-m-cell-life-activities",
      "text": "运用示意图或模型等方式，展示和说明细胞各结构的功能及其相互关系。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-cell-basis-bio-m-cell-life-activities",
      "text": "指导学生制作临时装片，利用显微镜进行观察，使学生初步学会使用显微镜观察的方法，形成对细胞结构的感性认识。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biosphere-bio-m-biosphere-largest",
      "text": "生物圈是包含多种类型生态系统的最大生态系统",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biosphere-bio-m-biosphere-largest",
      "text": "分析人类活动对生态环境造成破坏的实例，形成保护生物圈的社会责任意识。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biosphere-bio-m-biosphere-largest",
      "text": "通过各种途径收集生物圈的相关资料，模拟召开“生物圈国际保护”研讨会，结合本地实际讨论如何保护生物圈。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-cell-basis-bio-m-cell-division-m",
      "text": "细胞能通过分裂和分化形成不同的组织",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-cell-basis-bio-m-cell-division-m",
      "text": "描述细胞分裂和分化的基本过程；识别人体和植物体的主要组织；说明细胞通过分裂和分化形成各种组织，组织构成不同的器官",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-cell-basis-bio-m-cell-division-m",
      "text": "引导学生通过观察某种器官不同组织的特点，基于事实进行科学推理，深入理解细胞分化的概念",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-cell-basis-bio-m-tissue-types",
      "text": "功能不同的组织可以形成器官，共同完成某种生理功能的器官可以形成系统。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-cell-basis-bio-m-tissue-types",
      "text": "绿色开花植物体的结构层次包括细胞、组织、器官和个体，高等动物体的结构层次包括细胞、组织、器官、系统和个体。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-cell-basis-bio-m-tissue-types",
      "text": "识别给定生物材料所属的结构层次，并阐明生物体在结构和功能上是一个有机整体。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-plant-structure",
      "text": "植物分布广泛，直接或间接地为其他生物提供食物和能量；植物参与生物圈中的水循环，维持生物圈中的碳氧平衡。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-plant-structure",
      "text": "通过本主题的学习，学生能够理解植物体的构造与功能、植物的生活与生产、植物在生物圈中的作用。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-plant-structure",
      "text": "识别给定生物材料所属的结构层次，并阐明生物体在结构和功能上是一个有机整体。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-cell-division-junior",
      "text": "细胞能通过分裂和分化形成不同的组织",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-cell-division-junior",
      "text": "描述细胞分裂和分化的基本过程；识别人体和植物体的主要组织；说明细胞通过分裂和分化形成各种组织",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-cell-division-junior",
      "text": "引导学生通过观察某种器官不同组织的特点，基于事实进行科学推理，深入理解细胞分化的概念",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biosphere-bio-m-food-chain",
      "text": "生态系统中不同生物之间通过捕食关系形成了食物链和食物网",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biosphere-bio-m-food-chain",
      "text": "运用图示或模型表示生态系统中各生物成分之间的营养关系",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biosphere-bio-m-food-chain",
      "text": "结合具体实例，引导学生分析生态系统中各成分的作用及其相互关系，并用恰当的形式呈现，发展学生的建模思维",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-cell-basis-bio-m-cell-structure-m",
      "text": "动物细胞、植物细胞都具有细胞膜、细胞质、细胞核等结构。植物细胞具有不同于动物细胞的结构，如叶绿体和细胞壁。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-cell-basis-bio-m-cell-structure-m",
      "text": "识别动植物细胞的结构并说出其异同点，说明细胞是生物体结构和功能的基本单位。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-cell-basis-bio-m-cell-structure-m",
      "text": "制作植物细胞、动物细胞的临时装片，用显微镜观察细胞结构；尝试制作植物细胞或动物细胞的结构模型。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-cell-basis-bio-m-microscope-use",
      "text": "正确、规范地制作临时装片，使用显微镜进行观察，能够针对观察结果中可能出现的成像不佳等情况，从材料制备、仪器设备、操作程序等方面初步分析原因。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-cell-basis-bio-m-microscope-use",
      "text": "为学生提供多种生物材料，指导学生制作临时装片，利用显微镜进行观察，使学生初步学会使用显微镜观察的方法，形成对细胞结构的感性认识。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-cell-basis-bio-m-microscope-use",
      "text": "实验探究活动: 练习使用光学显微镜; 用显微镜观察池塘水中的微小生物;制作植物细胞、动物细胞的临时装片，用显微镜观察细胞结构。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biosphere-bio-m-eco-factors",
      "text": "生态因素能够影响生物的生活和分布，生物能够适应和影响环境",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biosphere-bio-m-eco-factors",
      "text": "从结构与功能的角度，阐明生态系统中的生产者、消费者、分解者以及非生物环境是一个有机整体",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biosphere-bio-m-eco-factors",
      "text": "通过资料分析、调查、实验探究等活动，引导学生认识生物与环境的关系",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biosphere-bio-m-eco-factors",
      "text": "探究影响鼠妇（或蚯蚓等）分布的环境因素，探究植被类型与环境湿度或温度之间的关系",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biosphere-bio-m-bio-characteristics",
      "text": "细胞是生物体结构和功能的基本单位。细胞的分裂、分化和生长是细胞重要的生命活动。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biosphere-bio-m-bio-characteristics",
      "text": "识别动植物细胞的结构并说出其异同点，说明细胞是生物体结构和功能的基本单位。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biosphere-bio-m-bio-characteristics",
      "text": "为学生提供多种生物材料，指导学生制作临时装片，利用显微镜进行观察，使学生初步学会使用显微镜观察的方法，形成对细胞结构的感性认识。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-cell-basics",
      "text": "细胞是生物体结构和功能的基本单位",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-cell-basics",
      "text": "识别动植物细胞的结构并说出其异同点，说明细胞是生物体结构和功能的基本单位。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-cell-basics",
      "text": "指导学生制作临时装片，利用显微镜进行观察，使学生初步学会使用显微镜观察的方法，形成对细胞结构的感性认识。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biodiversity-bio-m-ecosystem-junior",
      "text": "生态系统是由生产者、消费者、分解者与非生物环境构成的有机整体。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biodiversity-bio-m-ecosystem-junior",
      "text": "运用图示或模型表示生态系统中各生物成分之间的营养关系。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biodiversity-bio-m-ecosystem-junior",
      "text": "分析某生态系统受到破坏的具体实例，阐明生态系统的自我调节能力是有限的。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biodiversity-bio-m-ecosystem-junior",
      "text": "结合具体实例，引导学生分析生态系统中各成分的作用及其相互关系，并用恰当的形式呈现，发展学生的建模思维。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-seed-structure",
      "text": "概念4 植物有自己的生命周期，可以制造有机物，直接或间接地为其他生物提供食物，参与生物圈的水循环，并维持碳氧平衡。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-seed-structure",
      "text": "4.1.1 种子包括种皮和胚等结构，种子萌发需要完整、有活力的胚，需要充足的空气、适宜的温度、适量的水等环境条件。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-seed-structure",
      "text": "描述种子萌发的过程和条件；说明植物体的结构层次；阐明植物体在结构和功能上是一个统一整体。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-seed-structure",
      "text": "实验探究活动：探究种子萌发的条件；观察根尖的结构；观察芽的结构和发育。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-photosynthesis-m",
      "text": "概念 3.1.5 生态系统中的物质和能量通过食物链在生物之间传递",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-photosynthesis-m",
      "text": "通过本主题的学习，学生能够认识到植物分布广泛，直接或间接地为其他生物提供食物和能量；植物参与生物圈中的水循环，维持生物圈中的碳氧平衡。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-root-tip",
      "text": "植物通过根吸收水和无机盐，满足植物生长发育的需要。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-root-tip",
      "text": "根尖是根吸收水和无机盐的主要部位。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-root-tip",
      "text": "通过实验，探究植物对水和无机盐的吸收、运输和散失过程。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-root-tip",
      "text": "实验探究活动：探究植物对水和无机盐的吸收、运输和散失。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-stem-transport",
      "text": "概念4 植物通过吸收作用和蒸腾作用参与生物圈的水循环，通过光合作用和呼吸作用参与生物圈的碳氧平衡",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-stem-transport",
      "text": "4.2 植物通过吸收、运输和蒸腾作用参与生物圈的水循环",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-stem-transport",
      "text": "4.2.2 植物茎中具有运输功能的输导组织",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-reproduction-bio-m-flower-structure",
      "text": "概念4 植物有自己的生命周期，可以制造有机物，直接或间接地为其他生物提供食物，参与生物圈的水循环，并维持碳氧平衡。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-reproduction-bio-m-flower-structure",
      "text": "4.2.1 花是植物的生殖器官，其结构有利于完成传粉和受精。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-reproduction-bio-m-flower-structure",
      "text": "4.2.2 植物可以通过不同的媒介（如风、昆虫）完成传粉。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-reproduction-bio-m-asexual-reproduction",
      "text": "无性生殖是植物繁殖的一种方式，如扦插、嫁接等，能够保持母本的优良性状。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-reproduction-bio-m-asexual-reproduction",
      "text": "通过观察或实验，描述植物的无性生殖过程，并举例说明其在农业生产中的应用。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-reproduction-bio-m-asexual-reproduction",
      "text": "组织学生开展植物扦插、嫁接等实践活动，体验无性生殖的技术方法。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-human-body-bio-m-respiratory-system",
      "text": "人体生理与健康主题包含呼吸系统与气体交换等内容，学生应掌握人体各系统的结构和功能。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-human-body-bio-m-respiratory-system",
      "text": "学生能够说明呼吸系统与气体交换的基本过程，理解其对人体的重要性。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-human-body-bio-m-respiratory-system",
      "text": "通过实验探究活动，如模拟呼吸运动或测量肺活量，帮助学生理解呼吸系统的结构与功能。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-reproduction-bio-m-plant-classification",
      "text": "根据生物的形态结构、生理功能以及繁殖方式等，可以将生物分为不同的类群。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-reproduction-bio-m-plant-classification",
      "text": "藻类是能够进行光合作用的结构简单的生物。苔藓、蕨类、裸子植物和被子植物都具有根、茎、叶等器官的分化，植物繁殖过程逐渐摆脱了对水环境的依赖。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-reproduction-bio-m-plant-classification",
      "text": "通过列表等多种方式，对不同生物类群的形态结构、生活环境、繁殖方式等进行比较，帮助学生逐步形成生物具有多样性和统一性的认识。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-respiration-m",
      "text": "概念4 植物通过光合作用和呼吸作用参与生物圈中的物质循环和能量流动，维持生物圈中的碳氧平衡。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-respiration-m",
      "text": "4.2.2 植物通过呼吸作用分解有机物，释放能量，供给植物生命活动的需要。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-respiration-m",
      "text": "（2）通过实验探究绿色植物的光合作用和呼吸作用，阐明绿色植物在生物圈中的作用。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-biosphere",
      "text": "生态系统中的生物与非生物环境相互作用，实现了物质循环和能量流动。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-biosphere",
      "text": "从结构与功能的角度，阐明生态系统中的生产者、消费者、分解者以及非生物环境是一个有机整体。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-biosphere",
      "text": "分析人类活动对生态环境造成破坏的实例，形成保护生物圈的社会责任意识。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-biosphere",
      "text": "结合具体实例，引导学生分析生态系统中各成分的作用及其相互关系，并用恰当的形式呈现，发展学生的建模思维。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-transpiration",
      "text": "植物通过根吸收水分，通过导管运输水分，通过叶片散失水分，从而参与生物圈中的水循环。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-transpiration",
      "text": "阐明植物在生物圈水循环中的作用。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-transpiration",
      "text": "通过实验，探究蒸腾作用的主要器官。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-human-body-bio-m-circulatory-system",
      "text": "人体生理与健康主题包含血液循环系统相关内容，学生应掌握人体生理与健康的基础知识。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-human-body-bio-m-circulatory-system",
      "text": "学生应能说明血液循环系统等器官系统在维持人体正常生理功能中的作用。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-human-body-bio-m-circulatory-system",
      "text": "通过观察模型、示意图或视频等，引导学生理解血液循环系统的结构与功能。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-human-body-overview",
      "text": "人体生理与健康是课程内容七个学习主题之一，包含人体概述与消化系统等基础知识。",
      "source": "课程内容",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-human-body-overview",
      "text": "获得人体生理与健康等方面的基础知识；初步形成生物学的结构与功能观等生命观念。",
      "source": "目标要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-human-body-overview",
      "text": "关注身体内外各种因素对健康的影响，在饮食作息等方面形成健康生活的态度和行为习惯。",
      "source": "目标要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-circulation-respiration",
      "text": "人体生理与健康学习主题包括循环系统与呼吸系统等内容，要求学生掌握人体生理与健康的基础知识。",
      "source": "课程内容",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-circulation-respiration",
      "text": "学生应获得人体生理与健康等方面的基础知识，初步形成结构与功能观等生命观念。",
      "source": "目标要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-circulation-respiration",
      "text": "树立健康意识和社会责任感，关注身体内外各种因素对健康的影响，形成健康生活的态度和行为习惯。",
      "source": "目标要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-leaf-structure",
      "text": "植物细胞具有不同于动物细胞的结构，如叶绿体和细胞壁等。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-leaf-structure",
      "text": "识别动植物细胞的结构并说出其异同点，说明细胞是生物体结构和功能的基本单位。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-life-bio-m-leaf-structure",
      "text": "指导学生在感性认识的基础上，通过比较、归纳等方法，找出不同类型细胞的共同特征，并运用模式图或模型等方式展现细胞的结构。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biosphere-bio-m-biosphere-scope",
      "text": "生态系统是由生产者、消费者、分解者与非生物环境构成的有机整体。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biosphere-bio-m-biosphere-scope",
      "text": "从结构与功能的角度，阐明生态系统中的生产者、消费者、分解者以及非生物环境是一个有机整体。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biosphere-bio-m-biosphere-scope",
      "text": "结合具体实例，引导学生分析生态系统中各成分的作用及其相互关系，并用恰当的形式呈现，发展学生的建模思维。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-human-body-bio-m-excretory-system",
      "text": "概念5 人体通过泌尿系统排出代谢废物，维持内环境的稳定",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-human-body-bio-m-excretory-system",
      "text": "5.3.1 泌尿系统包括肾脏、输尿管、膀胱和尿道等器官",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-human-body-bio-m-excretory-system",
      "text": "5.3.2 肾脏是形成尿液的器官，其结构和功能的基本单位是肾单位",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-human-body-bio-m-excretory-system",
      "text": "5.3.3 尿液的生成和排出过程受神经和激素的调节",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biodiversity-bio-m-bio-classification",
      "text": "根据生物之间的相似程度将生物划分为界、门、纲、目、科、属、种等分类等级",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biodiversity-bio-m-bio-classification",
      "text": "说明生物的不同分类等级及其相互关系，初步形成生物进化的观点。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biodiversity-bio-m-bio-classification",
      "text": "充分利用本地的生物资源，组织学生识别生物的特征，尝试开展分类活动。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-animal-microbe-bio-m-infectious-disease",
      "text": "2.3.4 有些微生物会使人患病，有些微生物在食品生产、医药工业等方面得到广泛应用",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-animal-microbe-bio-m-infectious-disease",
      "text": "5. 树立健康意识和社会责任感，能够强身健体和服务社会。关注身体内外各种因素对健康的影响，在饮食作息、体育锻炼、疾病预防等方面形成健康生活的态度和行为习惯",
      "source": "课程目标",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-reproduction-development",
      "text": "概念1 生物体具有一定的结构层次，能够完成各项生命活动。1.2.2 高等动物体的结构层次包括细胞、组织、器官、系统和个体。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-reproduction-development",
      "text": "描述细胞分裂和分化的基本过程；识别人体和植物体的主要组织；说明细胞通过分裂和分化形成各种组织，组织构成不同的器官。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-reproduction-development",
      "text": "运用实物、图片、影像资料等教学资源，直观展现多细胞生物体的结构层次，引导学生形成生物体是一个统一整体的认识。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-microorganism-health",
      "text": "有些微生物会使人患病，有些微生物在食品生产、医药工业等方面得到广泛应用。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-microorganism-health",
      "text": "病毒无细胞结构，需要在活细胞内完成增殖；细菌是单细胞生物，无成形的细胞核；真菌是单细胞或多细胞生物，有成形的细胞核。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-microorganism-health",
      "text": "培养并观察细菌的菌落，用放大镜或显微镜观察酵母菌和霉菌。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biodiversity-bio-m-biodiversity-m",
      "text": "我国拥有丰富的动植物资源，保护生物的多样性是每个人应有的责任。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biodiversity-bio-m-biodiversity-m",
      "text": "主动宣传生物多样性的重要意义，自觉遵守相关法律法规，保护生物多样性。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-biodiversity-bio-m-biodiversity-m",
      "text": "组织学生收集生物资源安全方面的资料和生物多样性保护的典型实例，在课堂上进行展示、交流和讨论。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-animal-microbe-bio-m-microorganism",
      "text": "微生物一般是指个体微小、结构简单的生物，主要包括病毒、细菌和真菌。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-animal-microbe-bio-m-microorganism",
      "text": "病毒无细胞结构，需要在活细胞内完成增殖。细菌是单细胞生物，无成形的细胞核。真菌是单细胞或多细胞生物，有成形的细胞核。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-animal-microbe-bio-m-microorganism",
      "text": "有些微生物会使人患病，有些微生物在食品生产、医药工业等方面得到广泛应用。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-animal-microbe-bio-m-microorganism",
      "text": "培养并观察细菌的菌落，用放大镜或显微镜观察酵母菌和霉菌。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-plant-reproduction",
      "text": "藻类是能够进行光合作用的结构简单的生物；苔藓植物、蕨类植物、种子植物具有根、茎、叶等器官的分化，植物繁殖过程逐渐摆脱了对水环境的依赖。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-plant-reproduction",
      "text": "通过列表等多种方式，对不同生物类群的形态结构、生活环境、繁殖方式等进行比较，帮助学生逐步形成生物具有多样性和统一性的认识。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-plant-reproduction",
      "text": "观察不同类群的动植物，认识其主要特征。",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-reproduction-bio-m-fruit-seed-formation",
      "text": "概念4 植物有自己的生命周期，可以制造有机物，直接或间接地为其他生物提供食物，参与生物圈的水循环，并维持碳氧平衡。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-reproduction-bio-m-fruit-seed-formation",
      "text": "4.2.2 花经过传粉和受精后形成果实和种子。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-plant-reproduction-bio-m-fruit-seed-formation",
      "text": "描述花的基本结构，阐明花与果实和种子形成的关系。",
      "source": "学业要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-biology-cross-disciplinary-practice",
      "text": "设置“生物学与社会·跨学科实践”学习主题，引导学生综合运用生物学、化学、物理、地理、数学等学科的相关知识和方法，尝试分析和解决实际问题。",
      "source": "课程理念",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-biology-cross-disciplinary-practice",
      "text": "“生物学与社会·跨学科实践”学习主题与其他6个学习主题构成了完整的课程内容体系，它们之间是相互融合的关系。该主题约占总课时数的10%。",
      "source": "课程内容",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-biology-cross-disciplinary-practice",
      "text": "探究实践是源于对自然界的好奇心、求知欲和现实需求，解决真实情境中的问题或完成实践项目的能力与品格。探究实践活动主要包括科学探究和跨学科实践。",
      "source": "核心素养内涵",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-biology-cross-disciplinary-practice",
      "text": "初步具有科学探究和跨学科实践能力，能够分析解决真实情境中的生物学问题。能够综合运用生物学和其他学科的知识、方法与实验操作技能，采用工程技术手段，通过设计、制作和改进，形成物化成果。",
      "source": "目标要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-animal-microbe-bio-m-animal-diversity",
      "text": "无脊椎动物与人类关系密切，如线虫动物、环节动物等",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-animal-microbe-bio-m-animal-diversity",
      "text": "脊椎动物（鱼类、两栖类、爬行类、鸟类、哺乳类）都具有适应其生活方式和环境的主要特征",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-animal-microbe-bio-m-animal-diversity",
      "text": "通过列表等多种方式，对不同生物类群的形态结构、生活环境、繁殖方式等进行比较",
      "source": "教学提示",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-human-body-bio-m-nervous-system-m",
      "text": "神经系统由脑、脊髓及与它们相连的神经构成",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-human-body-bio-m-nervous-system-m",
      "text": "反射是神经调节的基本方式，反射弧是反射的结构基础",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-urinary-nervous",
      "text": "人体主要通过泌尿系统排出代谢废物和多余的水。泌尿系统包括肾脏、输尿管、膀胱和尿道等结构。",
      "source": "内容要求",
      "type": "curriculum_point"
    },
    {
      "kp_id": "kp-bio-m-junior-biology-bio-m-urinary-nervous",
      "text": "血液经过肾小球和肾小囊的滤过作用及肾小管的重吸收作用形成尿液。",
      "source": "内容要求",
      "type": "curriculum_point"
