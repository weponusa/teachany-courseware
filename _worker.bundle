function inferBackendIdForModel(model) {
  const m = String(model || "").trim();
  if (!m) return "siliconflow";
  if (!m.includes("/")) return "paratera";
  if (/^(deepseek-ai|Qwen|THUDM|zai-org|baidu|tencent|moonshotai|MiniMax|Pro\/)/i.test(m)) {
