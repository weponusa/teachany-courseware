.DS_Store
node_modules/
**/node_modules/
.cache/
**/.cache/
dist/
**/dist/
*.log
__pycache__/
*.pyc

# admin 本地标记（rebuild-index.py 权限校验用）
.teachany-admin

# Remotion 渲染产物（视频已复制到课件 assets/ 引用，out/ 为可再生构建副本）
**/remotion/out/
**/remotion/.remotion/
# 一次性备份 / 重复归档（不进仓库，靠 git 历史可追溯）
_archive_*/
community/archive/duplicates-*/

# 阅读互动助手预生成场景图（已改用 Agnes API 动态生成，不入仓库）
community/reading-academy/assets/generated-scenes/
# 阅读互动助手批处理日志
community/reading-academy/batch_gen.log
community/archive/pending-duplicates-*/
# 已解包课件目录内不应再提交 .teachany 包（pending 提交流程除外）
community/*/*.teachany
community/*/**/.teachany
_site/
