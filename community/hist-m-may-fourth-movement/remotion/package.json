{
  "name": "remotion-may-fourth",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render RemotionMayFourth ./video/may-fourth.mp4 --width 1920 --height 1080 --fps 30 --codec libx264 --crf 23",
